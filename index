function parseMoney(v){
  if(v===""||v==null) return 0;
  return Math.max(0, Number(String(v).replace(/[^0-9.\-]/g,"")) || 0);
}
function parseIntSafe(v, d=0){ const n=parseInt(v,10); return isNaN(n)?d:n; }
