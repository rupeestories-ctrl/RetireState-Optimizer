function generateRecommendation(p, rows){
  const best = rows[0];
  const worst = rows[rows.length-1];
  const horizon = Math.max(1,p.horizon);
  const annualDiff = worst.impact - best.impact;
  const horizonDiff = worst.cumulativeImpact - best.cumulativeImpact;
  const band = netWorthBand(p.netWorth);

  const pureTax = [...rows].sort((a,b)=>a.incomeTax-b.incomeTax)[0];
  const lowCost = [...rows].sort((a,b)=>(a.col+a.salesTax+a.hc)-(b.col+b.salesTax+b.hc))[0];
  const hiddenCost = [...rows].sort((a,b)=>(b.propertyTax+b.ins+b.salesTax)-(a.propertyTax+a.ins+a.salesTax))[0];
  const looksCheap = [...rows].filter(r=>!r.s.hasStateIncomeTax).sort((a,b)=>b.impact-a.impact)[0];
  const looksPricey = [...rows].filter(r=>r.s.hasStateIncomeTax).sort((a,b)=>a.incomeTax-b.incomeTax)[0];

  let html = `<span class="band">Net-worth band: ${band.label}</span>`;
  html += `<p>Across the states you compared over a ${horizon}-year horizon, <strong>${best.s.stateName}</strong> comes out ahead, leaving an estimated <strong>${fmtUSD(best.projected)}</strong> versus <strong>${fmtUSD(worst.projected)}</strong> in ${worst.s.stateName} — a gap of about <strong>${fmtUSD(horizonDiff)}</strong>, or roughly <strong>${fmtUSD(annualDiff)}</strong> per year.</p>`;
  html += `<p>At your net worth, the factors that matter most are ${band.focus}.</p>`;

  html += `<h3>How the states stack up</h3><ul>`;
  html += `<li><b>Best overall:</b> ${best.s.stateName}, with the lowest total annual state impact for your specific mix of income, housing, and spending.</li>`;
  html += `<li><b>Best pure income-tax state:</b> ${pureTax.s.stateName}, at about ${fmtUSD(pureTax.incomeTax)}/yr of modeled state income tax.</li>`;
  html += `<li><b>Lowest day-to-day cost:</b> ${lowCost.s.stateName}, based on cost of living, sales tax, and healthcare adjustments.</li>`;
  html += `<li><b>Highest hidden-cost state:</b> ${hiddenCost.s.stateName}, where property tax, insurance, and sales tax add about ${fmtUSD(hiddenCost.propertyTax + hiddenCost.ins + hiddenCost.salesTax)}/yr.</li>`;
  if(looksCheap && looksCheap.impact > best.impact * 1.05){
    html += `<li><b>Looks cheap but is not:</b> ${looksCheap.s.stateName} has no state income tax, but still lands at about ${fmtUSD(looksCheap.impact)}/yr once property tax, insurance, and other state costs are counted.</li>`;
  }
  if(looksPricey && looksPricey.incomeTax < worst.incomeTax){
    html += `<li><b>Looks expensive but retiree-friendly:</b> ${looksPricey.s.stateName} has an income tax on paper, but retirement-income treatment keeps your modeled state income tax to about ${fmtUSD(looksPricey.incomeTax)}/yr.</li>`;
  }
  html += `</ul>`;

  html += `<h3>What's driving your result</h3>`;
  const drivers = [];
  if(p.iraWithdrawals > 60000){
    drivers.push(`Because your plan uses ${fmtUSD(p.iraWithdrawals)}/yr from traditional retirement accounts, states that tax IRA and 401(k) withdrawals create a real annual drag and can materially reshape the ranking.`);
  }
  if(p.ownership === "own" && p.homeValue > 750000){
    drivers.push(`Because your home value is ${fmtUSD(p.homeValue)}, property tax can matter as much as income tax. A no-income-tax state is not automatically the lowest-cost state once the property-tax bill is included.`);
  }
  const rothShare = p.rothWithdrawals / Math.max(1, calculateAnnualIncome(p));
  if(rothShare > 0.4 || (p.rothBalance > p.iraBalance + p.brokerage && p.rothBalance > 0)){
    drivers.push(`Because much of your retirement income comes from Roth accounts, state income tax matters less. Property tax, insurance, and cost of living become more important drivers.`);
  }
  if(p.netWorth > 5000000){
    drivers.push(`Because your net worth is above $5 million, estate and inheritance tax rules deserve special attention. At this level, they can outweigh smaller annual tax differences.`);
  }
  if(p.ssIncome <= 0){
    drivers.push(`You reported no Social Security income, so Social Security taxation is not a meaningful factor in this comparison.`);
  }
  if(p.ownership === "rent"){
    drivers.push(`Because you rent, property tax and homeowners insurance are zero in every state, so cost of living, sales tax, and healthcare play a larger role. Your rent is treated as the same in every state and shown only for context.`);
  }
  if(!drivers.length){
    drivers.push(`Your income is reasonably balanced across sources, so the ranking is driven by the combination of income tax, property tax, and cost of living rather than any single factor.`);
  }
  drivers.forEach(d => { html += `<p>${d}</p>`; });

  html += `<h3>Plain-English takeaway</h3><p>${narrativeTakeaway(p, rows)}</p>`;
  return html;
}

function calculate(){
  if(selectedStates.length<2 || selectedStates.length>4){
    toast("Choose 2 to 4 beta states.");
    return;
  }
  const rows = rankStates(profile, selectedStates);
  lastRows = rows;
  renderReport(profile, rows);
}

function renderReport(p, rows){
  const rep=document.getElementById("report");
  rep.className="";
  const horizon = Math.max(1,p.horizon);
  const best = rows[0];
  const worst = rows[rows.length-1];
  const housing = calculateHousingCost(p);

  let h=`<div class="section"><h2><span class="n">3</span> Overview</h2>`;
  h+=`<div class="cards">
    <div class="card accent-good"><div class="k">Best state</div><div class="v">${esc(best.s.stateName)}</div><div class="sub">${fmtUSD(best.impact)}/yr annual state impact</div></div>
    <div class="card accent-bad"><div class="k">Most expensive</div><div class="v">${esc(worst.s.stateName)}</div><div class="sub">${fmtUSD(worst.impact)}/yr annual state impact</div></div>
    <div class="card accent-gold"><div class="k">Annual spread</div><div class="v">${fmtUSD(worst.impact-best.impact)}</div><div class="sub">Difference between highest and lowest annual state impact</div></div>
    <div class="card accent-ink"><div class="k">Cumulative spread</div><div class="v">${fmtUSD(worst.cumulativeImpact-best.cumulativeImpact)}</div><div class="sub">Cumulative state impact, inflated annually</div></div>
  </div></div>`;

  h+=`<div class="section"><h2><span class="n">4</span> State Ranking</h2><p class="hint">Ranked by State-Adjusted Net Worth Estimate after total annual state impact, compounded at ${p.inflation||0}%/yr inflation over ${horizon} years.</p>`;
  h+=`<div class="tablewrap"><table><thead><tr>
    <th class="left">Rank</th><th class="left">State</th><th class="left">Modeling Confidence</th><th>Income Tax</th><th>Property Tax</th><th>Sales Tax</th><th>Insurance</th><th>Cost-of-Living Adj.</th><th>Healthcare Adj.</th><th class="left">Estate/Inh.</th><th>Annual State Impact</th><th>Cumulative State Impact, Inflated Annually</th><th>State-Adjusted Net Worth Estimate</th><th class="left">Verdict</th>
  </tr></thead><tbody>`;
  rows.forEach(r=>{
    const rb = r.rank===1?"rank-1":(r.rank===rows.length?"rank-last":"rank-mid");
    const estFlag = (r.s.hasEstateTax?"Estate":"")+(r.s.hasEstateTax&&r.s.hasInheritanceTax?" + ":"")+(r.s.hasInheritanceTax?"Inherit.":"");
    const verds = verdictFor(p,r,rows).map(v=>`<span class="verdict ${v.c}">${v.t}</span>`).join(" ");
    h+=`<tr>
      <td class="left"><span class="rankbadge ${rb}">${r.rank}</span></td>
      <td class="left statecell">${esc(r.s.stateName)}<span class="abbr">${r.s.abbreviation}</span>${r.s.estimated?'<span class="est-tag">EST</span>':''}</td>
      <td class="left"><span class="conf conf-${r.confidence}">${r.confidence}</span></td>
      <td class="cell-num">${fmtUSD(r.incomeTax)}</td>
      <td class="cell-num">${fmtUSD(r.propertyTax)}</td>
      <td class="cell-num">${fmtUSD(r.salesTax)}</td>
      <td class="cell-num">${fmtUSD(r.ins)}</td>
      ${numCell(r.col)}
      ${numCell(r.hc)}
      <td class="left">${estFlag?`<span class="yes">${estFlag}</span>`:`<span class="no">None</span>`}</td>
      <td class="cell-num ${r.impact<0?'neg':''}"><strong>${signed(r.impact)}</strong></td>
      <td class="cell-num ${r.cumulativeImpact<0?'neg':''}">${signed(r.cumulativeImpact)}</td>
      <td class="cell-num"><strong>${fmtUSD(r.projected)}</strong></td>
      <td class="left">${verds}</td>
    </tr>`;
  });
  h+=`</tbody></table></div>`;
  h+=`<div class="assump"><strong>How to read this:</strong> Housing cost is shown for context. It is not used to rank states unless state-specific rent or home-price assumptions are added later. ${housing>0?`Your annual housing cost is ${fmtUSD(housing)}.`:''}</div></div>`;

  h+=`<div class="section"><h2><span class="n">5</span> Tax Treatment by State</h2>`;
  h+=`<div class="tablewrap"><table><thead><tr>
    <th class="left">State</th><th class="left">Modeling Confidence</th><th class="left">Social Security</th><th class="left">Pension</th><th class="left">IRA/401(k)</th><th class="left">Roth</th><th class="left">Interest/Div.</th><th class="left">LT Cap Gains</th><th class="left">Estate Tax</th><th class="left">Inheritance Tax</th>
  </tr></thead><tbody>`;
  rows.forEach(r=>{
    const s=r.s;
    const ss=ssDisplay(s.socialSecurityTaxTreatment), pen=incDisplay(s.pensionTaxTreatment), ira=incDisplay(s.ira401kTaxTreatment);
    const idv = s.hasStateIncomeTax?['yes','Yes']:['no','No'];
    const cg=cgDisplay(s.capitalGainsTaxTreatment);
    const cell=(d)=>`<td class="left"><span class="${d[0]}">${d[1]}</span></td>`;
    h+=`<tr><td class="left statecell">${esc(s.stateName)}<span class="abbr">${s.abbreviation}</span></td>
      <td class="left"><span class="conf conf-${r.confidence}">${r.confidence}</span></td>
      ${cell(ss)}${cell(pen)}${cell(ira)}<td class="left"><span class="no">No</span></td>${cell(idv)}${cell(cg)}
      <td class="left"><span class="${s.hasEstateTax?'yes':'no'}">${s.hasEstateTax?'Yes':'No'}</span></td>
      <td class="left"><span class="${s.hasInheritanceTax?'yes':'no'}">${s.hasInheritanceTax?'Yes':'No'}</span></td></tr>`;
  });
  h+=`</tbody></table></div>`;
  h+=`<div class="assump"><strong>Modeling Confidence</strong> reflects how simplified the state model is, not whether every underlying tax rule has been manually verified.</div></div>`;

  h+=`<div class="section no-print"><h2><span class="n">6</span> Red Flags by State</h2><div class="flagcols">`;
  rows.forEach(r=>{
    const flags=generateRedFlags(p,r.s,r);
    h+=`<div class="flagcard"><h3>${esc(r.s.stateName)} <span class="score">${flags.length} flag${flags.length===1?"":"s"}</span></h3>`;
    if(!flags.length){ h+=`<div class="noflags">● No major red flags for this profile.</div>`; }
    else { flags.forEach(f=>{ h+=`<div class="flag sev-${f.sev}"><span class="dot"></span><span><span class="ft">${esc(f.title)}</span>${esc(f.text)}</span></div>`; }); }
    h+=`</div>`;
  });
  h+=`</div></div>`;

  h+=`<div class="section"><h2><span class="n">7</span> Recommendation</h2><div class="reco">${generateRecommendation(p,rows)}</div></div>`;

  h+=`<div class="section"><div class="disclaimer"><strong>What this model does and doesn't include.</strong> It compares <em>state-level</em> costs only: state income tax, property tax, sales tax, insurance, and relative cost-of-living and healthcare differences, with annual costs inflated at ${p.inflation||0}%/yr. It does <strong>not</strong> model federal income tax, investment growth or returns, portfolio withdrawal sustainability, RMDs, Medicare/IRMAA surcharges, sequence-of-returns risk, home appreciation, or local/municipal income taxes. The state-adjusted net worth figure is a directional comparison between states, not a full retirement projection. Approximate 2025 tax-year rules, last reviewed ${DATA_VINTAGE}.</div></div>`;

  rep.innerHTML=h;
}

function exportCSV(){
  if(!lastRows){ toast("Calculate a comparison first."); return; }
  const housingCash=calculateHousingCost(profile);
  const head=["Rank","State","Modeling Confidence","State Income Tax","Property Tax","Sales Tax","Insurance","Cost-of-Living Adjustment","Healthcare Adjustment","Annual State Impact","Cumulative State Impact, Inflated Annually","State-Adjusted Net Worth Estimate","Annual Housing Cost","Verdict"];
  const esc2=v=>{ v=String(v); return /[",\n]/.test(v)?'"'+v.replace(/"/g,'""')+'"':v; };
  const lines=[head.map(esc2).join(",")];
  lastRows.forEach(r=>{
    lines.push([r.rank, r.s.stateName, r.confidence, Math.round(r.incomeTax), Math.round(r.propertyTax), Math.round(r.salesTax),
      Math.round(r.ins), Math.round(r.col), Math.round(r.hc), Math.round(r.impact), Math.round(r.cumulativeImpact), Math.round(r.projected), Math.round(housingCash),
      verdictFor(profile,r,lastRows).map(v=>v.t).join("; ")].map(esc2).join(","));
  });
  const blob=new Blob([lines.join("\n")],{type:"text/csv;charset=utf-8;"});
  const url=URL.createObjectURL(blob);
  const a=document.createElement("a"); a.href=url; a.download="retirestate-optimizer-beta.csv";
  document.body.appendChild(a); a.click(); document.body.removeChild(a); URL.revokeObjectURL(url);
  toast("CSV exported.");
}

function fallbackCopy(text, onDone){
  const ta = document.createElement("textarea");
  ta.value = text;
  ta.setAttribute("readonly", "");
  ta.style.position = "fixed";
  ta.style.top = "-9999px";
  ta.style.left = "-9999px";
  ta.style.opacity = "0";
  document.body.appendChild(ta);
  ta.focus();
  ta.select();
  ta.setSelectionRange(0, ta.value.length);
  try{
    const ok = document.execCommand("copy");
    document.body.removeChild(ta);
    if(ok){
      onDone();
    }else{
      toast("Copy failed. Select and copy manually.");
    }
  }catch(e){
    document.body.removeChild(ta);
    toast("Copy failed. Select and copy manually.");
  }
}

function copyReport(){
  if(!lastRows){
    toast("Calculate a comparison first.");
    return;
  }
  const text = document.getElementById("report").innerText;
  const done = ()=>toast("Report copied.");
  if(navigator.clipboard && window.isSecureContext){
    navigator.clipboard.writeText(text).then(done).catch(()=>fallbackCopy(text, done));
  }else{
    fallbackCopy(text, done);
  }
}

function printReport(){
  if(!lastRows){ toast("Calculate a comparison first."); return; }
  window.print();
}

let toastTimer;
function toast(msg){
  const t=document.getElementById("toast"); t.textContent=msg; t.classList.add("show");
  clearTimeout(toastTimer); toastTimer=setTimeout(()=>t.classList.remove("show"),2400);
}
function reset(){
  profile={...SAMPLE}; selectedStates=["PA","NJ","FL","TX"];
  buildForm(); buildStateGrid();
  lastRows=null;
  const rep=document.getElementById("report");
  rep.className="empty-state";
  rep.innerHTML=`<h2>Your comparison report will appear here</h2><p>Enter your details above, pick your states, and press <strong>Calculate Comparison</strong>.</p>`;
  toast("Reset to sample profile.");
}

buildForm();
buildPresets();
buildStateGrid();
document.getElementById("vintage").textContent = "Approximate 2025 tax-year rules, last reviewed " + DATA_VINTAGE + " · selected beta states only · all calculations run locally in your browser";
document.getElementById("btnCalc").addEventListener("click",calculate);
document.getElementById("btnReset").addEventListener("click",reset);
document.getElementById("btnCopy").addEventListener("click",copyReport);
document.getElementById("btnCsv").addEventListener("click",exportCSV);
document.getElementById("btnPrint").addEventListener("click",printReport);
calculate();
</script>
