function buildForm(){
  const grid=document.getElementById("formgrid");
  grid.innerHTML="";
  FIELDS.forEach(f=>{
    if(f.group){
      const d=document.createElement("div");
      d.className="fieldgroup-title";
      d.textContent=f.group;
      grid.appendChild(d);
      return;
    }
    const wrap=document.createElement("label");
    wrap.className="f";
    wrap.dataset.key=f.k;
    if(f.showIf && !f.showIf(profile)) wrap.classList.add("hidden");

    const lbl=document.createElement("div");
    lbl.className="lbl";
    lbl.textContent=f.label;
    wrap.appendChild(lbl);

    let input;
    if(f.type==="select"){
      input=document.createElement("select");
      f.opts.forEach(([val,txt])=>{
        const o=document.createElement("option");
        o.value=val; o.textContent=txt;
        if(profile[f.k]===val) o.selected=true;
        input.appendChild(o);
      });
    } else {
      input=document.createElement("input");
      input.type="text";
      input.className="num-in";
      input.value=profile[f.k] ?? "";
      input.inputMode="decimal";
    }
    input.dataset.key=f.k;
    input.addEventListener("input",onFieldChange);
    wrap.appendChild(input);

    if(f.k==="mortgage" || f.k==="rent"){
      const note=document.createElement("div");
      note.className="input-note";
      note.textContent="Housing cost is shown for context. It is not used to rank states unless state-specific rent or home-price assumptions are added later.";
      wrap.appendChild(note);
    }

    grid.appendChild(wrap);
  });
}

function onFieldChange(e){
  const k=e.target.dataset.key;
  const def=FIELDS.find(x=>x.k===k);
  if(!def) return;
  if(def.type==="select") profile[k]=e.target.value;
  else if(def.type==="int") profile[k]=parseIntSafe(e.target.value,0);
  else if(def.type==="pct") profile[k]=parseFloatSafe(e.target.value,0);
  else profile[k]=parseMoney(e.target.value);

  document.querySelectorAll("#formgrid label.f").forEach(l=>{
    const kk=l.dataset.key;
    const fd=FIELDS.find(x=>x.k===kk);
    if(fd && fd.showIf) l.classList.toggle("hidden", !fd.showIf(profile));
  });
}

